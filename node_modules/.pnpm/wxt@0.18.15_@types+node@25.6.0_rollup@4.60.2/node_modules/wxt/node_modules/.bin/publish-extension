esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/zjx/code/mine/web-pull/node_modules/.pnpm/publish-browser-extension@2.3.1/node_modules/publish-browser-extension/bin/node_modules:/home/zjx/code/mine/web-pull/node_modules/.pnpm/publish-browser-extension@2.3.1/node_modules/publish-browser-extension/node_modules:/home/zjx/code/mine/web-pull/node_modules/.pnpm/publish-browser-extension@2.3.1/node_modules:/home/zjx/code/mine/web-pull/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/zjx/code/mine/web-pull/node_modules/.pnpm/publish-browser-extension@2.3.1/node_modules/publish-browser-extension/bin/node_modules:/home/zjx/code/mine/web-pull/node_modules/.pnpm/publish-browser-extension@2.3.1/node_modules/publish-browser-extension/node_modules:/home/zjx/code/mine/web-pull/node_modules/.pnpm/publish-browser-extension@2.3.1/node_modules:/home/zjx/code/mine/web-pull/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../../../publish-browser-extension@2.3.1/node_modules/publish-browser-extension/bin/publish-extension.cjs" "$@"
else
  exec node  "$basedir/../../../../../publish-browser-extension@2.3.1/node_modules/publish-browser-extension/bin/publish-extension.cjs" "$@"
fi
